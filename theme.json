{
    "$schema": "https://schemas.wp.org/trunk/theme.json",
    "version": 3,
    "settings": {
        "appearanceTools": true,
        "layout": {
            "contentSize": "1200px",
            "wideSize": "1400px"
        },
        "color": {
            "palette": [
                {
                    "name": "Brand Groen",
                    "slug": "brand-green",
                    "color": "var(--sg-brand-green)"
                },
                {
                    "name": "Donker Groen",
                    "slug": "dark-green",
                    "color": "var(--sg-dark-green)"
                },
                {
                    "name": "Medium Groen",
                    "slug": "medium-green",
                    "color": "var(--sg-medium-green)"
                },
                {
                    "name": "Licht Groen",
                    "slug": "light-green",
                    "color": "var(--sg-light-green)"
                },
                {
                    "name": "Licht Grijs",
                    "slug": "light-grey",
                    "color": "var(--sg-light-grey)"
                },
                {
                    "name": "Indigo Blauw",
                    "slug": "indigo",
                    "color": "#5c6cf5"
                },
                {
                    "name": "Wit",
                    "slug": "white",
                    "color": "#ffffff"
                }
            ]
        },
        "typography": {
            "fontSizes": [
                { "name": "Klein",      "slug": "small",   "size": "0.875rem" },
                { "name": "Normaal",    "slug": "medium",  "size": "1rem" },
                { "name": "Groot",      "slug": "large",   "size": "1.5rem" },
                { "name": "Zeer groot", "slug": "x-large", "size": "2.25rem" }
            ]
        },
        "spacing": {
            "spacingSizes": [
                { "name": "Klein",   "slug": "small",  "size": "1rem" },
                { "name": "Normaal", "slug": "medium", "size": "2rem" },
                { "name": "Groot",   "slug": "large",  "size": "4rem" }
            ]
        }
    },
    "styles": {
        "color": {
            "background": "#ffffff",
            "text": "#000000"
        }
    }
}
