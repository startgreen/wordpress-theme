{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "useRootPaddingAwareAlignments": true,
    "color": {
      "palette": [
        {
          "slug": "green-primary",
          "color": "#1a7a4a",
          "name": "Green Primary"
        },
        {
          "slug": "green-light",
          "color": "#2ecc71",
          "name": "Green Light"
        },
        {
          "slug": "green-dark",
          "color": "#145c37",
          "name": "Green Dark"
        },
        {
          "slug": "white",
          "color": "#ffffff",
          "name": "White"
        },
        {
          "slug": "gray-50",
          "color": "#f9fafb",
          "name": "Gray 50"
        },
        {
          "slug": "gray-100",
          "color": "#f3f4f6",
          "name": "Gray 100"
        },
        {
          "slug": "gray-600",
          "color": "#4b5563",
          "name": "Gray 600"
        },
        {
          "slug": "gray-900",
          "color": "#111827",
          "name": "Gray 900"
        }
      ],
      "gradients": [
        {
          "slug": "green-to-dark",
          "gradient": "linear-gradient(135deg, #1a7a4a 0%, #145c37 100%)",
          "name": "Green to Dark Green"
        },
        {
          "slug": "green-to-light",
          "gradient": "linear-gradient(135deg, #145c37 0%, #2ecc71 100%)",
          "name": "Dark Green to Light Green"
        }
      ]
    },
    "typography": {
      "fontFamilies": [
        {
          "fontFamily": "Inter, sans-serif",
          "slug": "inter",
          "name": "Inter"
        },
        {
          "fontFamily": "Georgia, 'Times New Roman', serif",
          "slug": "serif",
          "name": "Serif"
        }
      ],
      "fontSizes": [
        { "slug": "xs",   "size": "0.75rem",  "name": "Extra Small" },
        { "slug": "sm",   "size": "0.875rem", "name": "Small" },
        { "slug": "base", "size": "1rem",     "name": "Base" },
        { "slug": "lg",   "size": "1.125rem", "name": "Large" },
        { "slug": "xl",   "size": "1.25rem",  "name": "Extra Large" },
        { "slug": "2xl",  "size": "1.5rem",   "name": "2X Large" },
        { "slug": "3xl",  "size": "1.875rem", "name": "3X Large" },
        { "slug": "4xl",  "size": "2.25rem",  "name": "4X Large" },
        { "slug": "5xl",  "size": "3rem",     "name": "5X Large" },
        { "slug": "6xl",  "size": "3.75rem",  "name": "6X Large" }
      ],
      "fluid": true
    },
    "spacing": {
      "spacingSizes": [
        { "slug": "1",  "size": "0.25rem", "name": "1" },
        { "slug": "2",  "size": "0.5rem",  "name": "2" },
        { "slug": "4",  "size": "1rem",    "name": "4" },
        { "slug": "6",  "size": "1.5rem",  "name": "6" },
        { "slug": "8",  "size": "2rem",    "name": "8" },
        { "slug": "12", "size": "3rem",    "name": "12" },
        { "slug": "16", "size": "4rem",    "name": "16" },
        { "slug": "20", "size": "5rem",    "name": "20" },
        { "slug": "24", "size": "6rem",    "name": "24" }
      ],
      "padding": true,
      "margin":  true,
      "blockGap": true
    },
    "layout": {
      "contentSize": "720px",
      "wideSize": "1200px"
    },
    "border": {
      "color":  true,
      "radius": true,
      "style":  true,
      "width":  true
    },
    "shadow": {
      "presets": [
        {
          "slug": "sm",
          "shadow": "0 1px 2px 0 rgb(0 0 0 / 0.05)",
          "name": "Small"
        },
        {
          "slug": "md",
          "shadow": "0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1)",
          "name": "Medium"
        },
        {
          "slug": "lg",
          "shadow": "0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1)",
          "name": "Large"
        },
        {
          "slug": "xl",
          "shadow": "0 20px 25px -5px rgb(0 0 0 / 0.1), 0 8px 10px -6px rgb(0 0 0 / 0.1)",
          "name": "Extra Large"
        }
      ]
    },
    "custom": {
      "transition": {
        "duration": "200ms",
        "easing": "cubic-bezier(0.4, 0, 0.2, 1)"
      }
    }
  },
  "styles": {
    "color": {
      "background": "#ffffff",
      "text": "#111827"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--inter)",
      "fontSize": "var(--wp--preset--font-size--base)",
      "lineHeight": "1.6"
    },
    "spacing": {
      "blockGap": "var(--wp--preset--spacing--8)"
    },
    "elements": {
      "link": {
        "color": {
          "text": "var(--wp--preset--color--green-primary)"
        },
        ":hover": {
          "color": {
            "text": "var(--wp--preset--color--green-dark)"
          }
        }
      },
      "h1": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--5xl)",
          "fontWeight": "700",
          "lineHeight": "1.1"
        }
      },
      "h2": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--4xl)",
          "fontWeight": "700",
          "lineHeight": "1.2"
        }
      },
      "h3": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--3xl)",
          "fontWeight": "600",
          "lineHeight": "1.3"
        }
      },
      "h4": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--2xl)",
          "fontWeight": "600",
          "lineHeight": "1.4"
        }
      },
      "h5": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--xl)",
          "fontWeight": "600",
          "lineHeight": "1.4"
        }
      },
      "h6": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--lg)",
          "fontWeight": "600",
          "lineHeight": "1.4"
        }
      }
    }
  },
  "templateParts": [
    {
      "name": "header",
      "title": "Header",
      "area": "header"
    },
    {
      "name": "footer",
      "title": "Footer",
      "area": "footer"
    }
  ],
  "customTemplates": [
    {
      "name": "blank",
      "title": "Blank",
      "postTypes": ["page", "post"]
    },
    {
      "name": "no-sidebar",
      "title": "No Sidebar",
      "postTypes": ["page", "post"]
    }
  ]
}
